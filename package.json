{
  "name": "nexa",
  "version": "0.1.0",
  "private": true,
  "description": "NEXA - Vite-based AI coding ecosystem platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --parallel --filter @nexa/web --filter @nexa/api --filter @nexa/worker dev",
    "dev:web": "pnpm --filter @nexa/web dev",
    "dev:api": "pnpm --filter @nexa/api dev",
    "dev:worker": "pnpm --filter @nexa/worker dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css,html}\"",
    "clean": "pnpm -r clean",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "prettier": "^3.1.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
