{
  "name": "@nexa/worker",
  "version": "0.0.1",
  "description": "BullMQ worker for NEXA",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
